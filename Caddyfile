# Caddyfile for OpenResearchDataPlanner
# Serves static SPA with proper routing + proxies feedback API

:3000 {
    root * /srv

    # Enable compression
    encode gzip zstd

    # Health check endpoint
    handle /health {
        respond 200
    }

    # Proxy feedback API to sidecar service
    handle /api/* {
        reverse_proxy feedback-api:4001
    }

    # SPA routing: try file, then index.html
    handle {
        try_files {path} /index.html
        file_server
    }

    # Cache static assets aggressively
    @static {
        path *.js *.css *.woff *.woff2 *.png *.jpg *.svg *.ico
    }
    header @static Cache-Control "public, max-age=31536000, immutable"

    # Don't cache HTML (for updates)
    @html {
        path *.html /
    }
    header @html Cache-Control "no-cache, must-revalidate"

    # Security headers
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
}
